---
import BaseLayout from "@layouts/BaseLayout.astro";
import layoutStyles from "@components/layout.module.css";
import { getAllPostsSortedAsc, formatDate } from "@lib/posts";
import { render } from "astro:content";
import type { InferGetStaticParamsType, InferGetStaticPropsType } from "astro";

export async function getStaticPaths() {
  const posts = await getAllPostsSortedAsc();

  return posts.map((post, index) => {
    const previous = index > 0 ? posts[index - 1] : null;
    const next = index < posts.length - 1 ? posts[index + 1] : null;

    return {
      params: { section: post.data.section, slug: post.data.slug },
      props: { post, previous, next },
    };
  });
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post, previous, next } = Astro.props;
const { Content } = await render(post);
const needsPagination = Boolean(previous) || Boolean(next);
---

<BaseLayout
  pageTitle={post.data.title}
  pathName={`/${post.data.section}/${post.data.slug}`}
>
  <h1>{post.data.title}</h1>
  <h6>{formatDate(post.data.date)} // {post.data.tag}</h6>
  {
    needsPagination && (
      <nav>
        <ul class={layoutStyles["nav-links"]}>
          {previous && (
            <li>
              <a
                href={`/${previous.data.section}/${previous.data.slug}`}
                class={layoutStyles["nav-link-text"]}
              >
                &nbsp;&nbsp;&nbsp;← {previous.data.title}
              </a>
            </li>
          )}
          <li class={layoutStyles.navSpacer}>&nbsp;</li>
          {next && (
            <li>
              <a
                href={`/${next.data.section}/${next.data.slug}`}
                class={layoutStyles["nav-link-text"]}
              >
                {next.data.title} →&nbsp;&nbsp;&nbsp;
              </a>
            </li>
          )}
        </ul>
      </nav>
    )
  }
  <Content />
  <p class="post-author">Article contributed by {post.data.author}</p>
  {
    needsPagination && (
      <nav>
        <ul class={layoutStyles["nav-links"]}>
          {previous && (
            <li>
              <a
                href={`/${previous.data.section}/${previous.data.slug}`}
                class={layoutStyles["nav-link-text"]}
              >
                &nbsp;&nbsp;&nbsp;← {previous.data.title}
              </a>
            </li>
          )}
          <li class={layoutStyles.navSpacer}>&nbsp;</li>
          {next && (
            <li>
              <a
                href={`/${next.data.section}/${next.data.slug}`}
                class={layoutStyles["nav-link-text"]}
              >
                {next.data.title} →&nbsp;&nbsp;&nbsp;
              </a>
            </li>
          )}
        </ul>
      </nav>
    )
  }
</BaseLayout>

<style>
  .post-author {
    margin: 0;
    margin-bottom: 10px;
    color: rgb(102, 102, 102);
    font-family: Menlo, Consolas, monospace;
    font-size: 0.8em;
    height: 20px;
    line-height: 20px;
    text-align: right;
    overflow: hidden;
  }
</style>
